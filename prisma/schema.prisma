generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

enum ApartmentStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id                Int      @id @default(autoincrement())
  firstName         String   @db.VarChar(50)  @map("first_name")
  lastName          String   @db.VarChar(50)  @map("last_name")

  phone             String   @unique @db.VarChar(12)
  email             String   @unique @db.VarChar(255)

  role              Role     @default(USER)
  isActive          Boolean  @default(true)   @map("is_active")

  password          String   @db.VarChar(255)

  isPhoneVerified   Boolean  @default(false)  @map("is_phone_verified")
  isEmailVerified   Boolean  @default(false)  @map("is_email_verified")
  verificationCode  String?  @db.VarChar(6)   @map("verification_code")

  // favourites        Favourite[]
  // bookings          Booking[]

  createdAt         DateTime @default(now())  @map("created_at")
  updatedAt         DateTime @updatedAt       @map("updated_at")

  @@map("users")
}

model ResidentialComplex {
  id              Int        @id @default(autoincrement())

  title           String     @db.VarChar(255)
  slug            String     @unique @db.VarChar(255)

  description     String?    @db.Text

  city            String     @db.VarChar(100)
  address         String     @db.VarChar(255)

  developerName   String?    @db.VarChar(255) @map("developer_name")

  completionDate  DateTime?  @map("completion_date")

  entrancesCount  Int?       @map("entrances_count")

  isPublished     Boolean    @default(false)  @map("is_published")

  apartments      Apartment[]
  files           File[]

  createdAt       DateTime   @default(now())  @map("created_at")
  updatedAt       DateTime   @updatedAt       @map("updated_at")

  @@map("residential_complexes")
}


model Apartment {
  id           Int               @id @default(autoincrement())

  complexId    Int
  complex      ResidentialComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  entrance     Int
  number       Int

  rooms        Int
  area         Decimal           @db.Decimal(10, 2)
  floor        Int
  price        Int

  status       ApartmentStatus   @default(AVAILABLE)
  description  String?           @db.Text
  isPublished  Boolean           @default(false)

  files        File[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([complexId, status])
  @@index([price])

  @@unique([complexId, entrance, number])

  @@map("apartments")
}


