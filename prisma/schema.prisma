generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        Int     @id @default(autoincrement())
  firstName String  @db.VarChar(50)  @map("first_name")
  lastName  String  @db.VarChar(50)  @map("last_name")

  phone     String  @db.VarChar(12)  @unique
  email     String  @db.VarChar(255)  @unique

  role      Role    @default(USER)
  isActive  Boolean @default(true) @map("is_active")

  password  String  @db.VarChar(255)

  isPhoneVerified   Boolean @default(false) @map("is_phone_verified")
  isEmailVerified   Boolean @default(false) @map("is_email_verified")
  verificationCode  String? @db.VarChar(6) @map("verification_code")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model ResidentialComplex {
  id             Int      @id @default(autoincrement())

  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)

  description    String?  @db.Text

  city           String   @db.VarChar(100)
  address        String   @db.VarChar(255)

  latitude       Float?
  longitude      Float?

  developerName  String?  @db.VarChar(255) @map("developer_name")
  completionDate DateTime? @map("completion_date")

  isPublished    Boolean  @default(false) @map("is_published")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("residential_complexes")
}